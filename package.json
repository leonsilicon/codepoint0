  "keywords": [
    "code-point",
    "string",
    "typescript",
    "unicode"
  ],
  "homepage": "https://github.com/leonsilicon/codepoint0#readme",
  "bugs": {
    "url": "https://github.com/leonsilicon/codepoint0/issues"
  },
  "license": "MIT",
  "author": "Leon Si <leon@leonsilicon.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonsilicon/codepoint0.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
